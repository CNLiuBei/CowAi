{
  "name": "tgauth-worker",
  "version": "1.0.0",
  "description": "TGAuth - Telegram + Cloudflare Authorization System",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:init": "wrangler d1 execute tgauth-db --file=./schema.sql",
    "db:init:local": "wrangler d1 execute tgauth-db --local --file=./schema.sql",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/node": "^20.11.0",
    "fast-check": "^3.15.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0",
    "wrangler": "^3.24.0"
  }
}
